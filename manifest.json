{
  "manifest_version": 3,
  "name": "BUG(Browsing Using Gestures",
  "version": "1.0.0",
  "description": "Do Browsing without hands",
  "permissions": [
  "sidePanel",
  "tabs",
  "activeTab",
  "scripting",
  "storage",
  "search"
],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "action": {
    "default_title": "Open Right Panel"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scripts/content.js"],
      "run_at": "document_idle"
    }
  ]
}
